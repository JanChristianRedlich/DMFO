# =============================================================
# DMFO Module: dmfo-activity (O_Act) + bridge O_bridge(St, Act)
#
# Anchor: prov:Activity (imported from PROV-O)
# Bridge: dmfo:stateWasGeneratedBy (State ↔ Activity)
#
# Alignment axiom contributed by this module:
#   (A5) dmfo:stateWasGeneratedBy ⊑ prov:wasGeneratedBy ,
#        typed dmfo:Manifestation × prov:Activity
#
# Discipline argument (Paper §3.2): A5 is a DMFO sub-property,
# not a global domain restriction on prov:wasGeneratedBy itself.
# Without this discipline, constraining prov:wasGeneratedBy to
# dmfo:Manifestation would infer Manifestation membership for
# any imported PROV prov:Entity appearing in subject position —
# an unintended global consequence over external PROV data.
#
# Reference: Paper §3.2, Table 1, Lebo et al. [15].
# =============================================================

@prefix dmfo:    <https://w3id.org/dmfo#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .

<https://w3id.org/dmfo/activity>
    a owl:Ontology ;
    owl:versionIRI <https://w3id.org/dmfo/activity/1.0.0> ;
    rdfs:label "DMFO Activity Module"@en ;
    rdfs:comment "Bridge dmfo:stateWasGeneratedBy, alignment axiom (A5)."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:imports <https://w3id.org/dmfo/state> ,
                <http://www.w3.org/ns/prov-o> .

# ── Bridge: State–Activity (A5) ───────────────────────────────

dmfo:stateWasGeneratedBy
    a owl:ObjectProperty ;
    rdfs:label "state was generated by"@en ;
    rdfs:isDefinedBy <https://w3id.org/dmfo> ;
    rdfs:domain dmfo:Manifestation ;
    rdfs:range  prov:Activity ;
    rdfs:subPropertyOf prov:wasGeneratedBy ;
    rdfs:comment """(A5) Localises the state-coupling commitment to the DMFO layer:
a Manifestation was generated by exactly the activities that the
PROV layer attributes to its state-bearing perdurant phase. Stated
as a sub-property of prov:wasGeneratedBy rather than a domain
restriction on it, to avoid global PROV-O contamination."""@en .
