# A5 — State-Activity sub-property
# dmfo:stateWasGeneratedBy is a sub-property of prov:wasGeneratedBy,
# typed Manifestation × prov:Activity.
PREFIX dmfo: <https://w3id.org/dmfo#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

ASK {
  dmfo:stateWasGeneratedBy rdfs:subPropertyOf prov:wasGeneratedBy ;
                           rdfs:domain dmfo:Manifestation ;
                           rdfs:range  prov:Activity .
}
