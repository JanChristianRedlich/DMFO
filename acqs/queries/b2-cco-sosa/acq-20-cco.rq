# ACQ-IV-04 (B2-CCO) — Governance gap
# Classification: (b) — direction reversed (no regulation prescribes).

PREFIX cco: <https://www.commoncoreontologies.org/>
PREFIX bfo: <http://purl.obolibrary.org/obo/>

SELECT ?act
WHERE {
  ?act a cco:ont00000005 .                    # cco:Act
  FILTER NOT EXISTS { ?reg cco:ont00001942 ?act }  # prescribes
}
