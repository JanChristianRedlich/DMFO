    dmfo:hasIdentifier "BL-5" ;
    dmfo:identifierScheme "urn:un:cefact:bl"^^xsd:anyURI .

ex:Decon_τ_5  a mar:DeconsolidationActivity ;
    prov:wasInformedBy ex:GateOut_5 ;
