    dmfo:evidencedBy          ex:Obs_GateRead_2 ;
    dmfo:manifestationTimestamp "2026-04-12T12:14:00Z"^^xsd:dateTimeStamp .

# Custody + customs situations
ex:Sit_Custody_2  a mar:CustodyTransferSituation ;
