@prefix b2cco:  <https://w3id.org/dmfo/baseline/cco#> .
@prefix b2mar:  <https://w3id.org/dmfo/baseline/cco/maritime#> .
@prefix bfo:    <http://purl.obolibrary.org/obo/> .
@prefix cco:    <https://www.commoncoreontologies.org/> .
@prefix ex:     <https://w3id.org/dmfo/baseline/cco/maritime/scale#> .
@prefix sosa:   <http://www.w3.org/ns/sosa/> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/dmfo/baseline/cco/maritime/scale-abox>
    a owl:Ontology ;
    owl:imports <https://w3id.org/dmfo/baseline/cco/maritime> .

ex:Berth_HHLA_CTA_03   a b2mar:Berth .
ex:Yard_CTA            a b2mar:TerminalYard .
ex:ISPSZone_CTA        a b2mar:ISPSZone ; bfo:BFO_0000171 ex:Yard_CTA .
ex:Gate_CTA_South      a b2mar:TerminalYard .
ex:CFS_CTA             a b2mar:CFS ; bfo:BFO_0000171 ex:Yard_CTA .
ex:Agent_CraneOp       a cco:ont00001017 .
ex:Agent_GateController a cco:ont00001017 .
ex:Agent_CFSOperator   a cco:ont00001017 .
ex:Sensor_AIS          a sosa:Sensor .
ex:Sensor_OCR          a sosa:Sensor .

ex:Regime_EU_UCC  a b2mar:RegulatoryRegime .
ex:Regime_ISPS    a b2mar:RegulatoryRegime .
ex:CONT_1  a b2mar:Container .
ex:BIC_1   a b2mar:BICCode ;
    cco:ont00001916 ex:CONT_1 ;
    rdfs:label "HLXU0000001" .

ex:Q_1_OnVessel    a b2mar:OnVesselLocationQuality ; bfo:BFO_0000197 ex:CONT_1 .
ex:Q_1_Discharged  a b2mar:DischargedLocationQuality ; bfo:BFO_0000197 ex:CONT_1 .
ex:Q_1_InYard      a b2mar:InYardLocationQuality ; bfo:BFO_0000197 ex:CONT_1 .
ex:Q_1_GateOut     a b2mar:GateOutLocationQuality ; bfo:BFO_0000197 ex:CONT_1 .

ex:Disch_1  a b2mar:VesselDischarge ;
    cco:ont00001833 ex:Agent_CraneOp ;
    cco:ont00001986 ex:Q_1_Discharged ;
    cco:ont00001918 ex:Berth_HHLA_CTA_03 .

ex:CraneTrf_1  a b2mar:CraneTransfer ;
    cco:ont00001833 ex:Agent_CraneOp ;
    cco:ont00001986 ex:Q_1_InYard ;
    cco:ont00001921 ex:Q_1_Discharged ;
    cco:ont00001918 ex:Yard_CTA ;
    bfo:BFO_0000062 ex:Disch_1 .

ex:GateOut_1  a b2mar:GateMovement ;
    cco:ont00001833 ex:Agent_GateController ;
    cco:ont00001986 ex:Q_1_GateOut ;
    cco:ont00001921 ex:Q_1_InYard ;
    cco:ont00001918 ex:Gate_CTA_South ;
    bfo:BFO_0000062 ex:CraneTrf_1 .

ex:Obs_AIS_1      a sosa:Observation ;
    sosa:hasFeatureOfInterest ex:Q_1_OnVessel ;
    sosa:resultTime "2026-04-12T08:07:00Z"^^xsd:dateTime ;
    sosa:phenomenonTime "2026-04-12T08:07:00Z"^^xsd:dateTime ;
    sosa:madeBySensor ex:Sensor_AIS .

ex:Obs_Disch_1    a sosa:Observation ;
    sosa:hasFeatureOfInterest ex:Q_1_Discharged ;
    sosa:resultTime "2026-04-12T08:13:00Z"^^xsd:dateTime ;
    sosa:phenomenonTime "2026-04-12T08:13:00Z"^^xsd:dateTime .

ex:Obs_GateRead_1 a sosa:Observation ;
    sosa:hasFeatureOfInterest ex:Q_1_GateOut ;
    sosa:resultTime "2026-04-12T12:07:00Z"^^xsd:dateTime ;
    sosa:phenomenonTime "2026-04-12T12:07:00Z"^^xsd:dateTime ;
    sosa:madeBySensor ex:Sensor_OCR .

# Variant-b Measurement ICEs (parallel, for native variant)
ex:Meas_AIS_1      a b2mar:AIS_Measurement ;
    cco:ont00001808 ex:Q_1_OnVessel .
ex:Meas_GateRead_1 a b2mar:GateRead_Measurement ;
    cco:ont00001808 ex:Q_1_GateOut .
ex:Meas_Disch_1    a b2mar:GateRead_Measurement ;
    cco:ont00001808 ex:Q_1_Discharged .

ex:CustodyTransfer_1  a b2mar:CustodyTransfer_Act ;
    bfo:BFO_0000171 ex:ISPSZone_CTA .
ex:CustomsControl_1   a b2mar:CustomsControl_Act ;
    bfo:BFO_0000171 ex:Gate_CTA_South .
ex:Regime_EU_UCC cco:ont00001942 ex:CustomsControl_1 .
ex:Regime_ISPS   cco:ont00001942 ex:CustodyTransfer_1 .
# Class IV gaps
ex:CONT_GAP_evidence  a b2mar:Container .
ex:BIC_GAP_evidence   a b2mar:BICCode ; cco:ont00001916 ex:CONT_GAP_evidence ; rdfs:label "GAPE0000001" .
ex:Q_GAP_NoEvidence   a b2mar:InYardLocationQuality ; bfo:BFO_0000197 ex:CONT_GAP_evidence .

ex:CONT_GAP_causal    a b2mar:Container .
ex:BIC_GAP_causal     a b2mar:BICCode ; cco:ont00001916 ex:CONT_GAP_causal ; rdfs:label "GAPC0000002" .
ex:Q_GAP_NoCausal     a b2mar:InYardLocationQuality ; bfo:BFO_0000197 ex:CONT_GAP_causal .

ex:CONT_GAP_scheme    a b2mar:Container .

ex:Sit_GAP_governance a cco:ont00000005 ; bfo:BFO_0000171 ex:Yard_CTA .
