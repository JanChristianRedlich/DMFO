    dmfo:stateWasGeneratedBy  ex:CraneTrf_2 ;
    dmfo:manifestationTimestamp "2026-04-12T08:24:00Z"^^xsd:dateTimeStamp .

ex:M_GateOut_2  a mar:GateOut ;
