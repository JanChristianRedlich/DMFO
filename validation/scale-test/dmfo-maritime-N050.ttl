    sosa:resultTime "2026-04-12T13:50:00Z"^^xsd:dateTime ;
    sosa:phenomenonTime "2026-04-12T13:50:00Z"^^xsd:dateTime ;
    sosa:madeBySensor ex:Sensor_AIS .

ex:Obs_Disch_50  a mar:Observation_GateRead ;
    sosa:hasFeatureOfInterest ex:M_Discharged_50 ;
    sosa:resultTime "2026-04-12T13:56:00Z"^^xsd:dateTime ;
    sosa:phenomenonTime "2026-04-12T13:56:00Z"^^xsd:dateTime .

ex:Obs_GateRead_50  a mar:Observation_GateRead ;
    sosa:hasFeatureOfInterest ex:M_GateOut_50 ;
    sosa:resultTime "2026-04-12T17:50:00Z"^^xsd:dateTime ;
    sosa:phenomenonTime "2026-04-12T17:50:00Z"^^xsd:dateTime ;
    sosa:madeBySensor ex:Sensor_OCR .

ex:M_OnVessel_50  a mar:OnVessel ;
    dmfo:manifestationOf      ex:CONT_50 ;
    dmfo:manifestationTimestamp "2026-04-12T13:20:00Z"^^xsd:dateTimeStamp .

ex:M_Discharged_50  a mar:Discharged ;
    dmfo:manifestationOf      ex:CONT_50 ;
    dmfo:stateWasGeneratedBy  ex:Disch_50 ;
    dmfo:evidencedBy          ex:Obs_Disch_50 ;
    dmfo:manifestationTimestamp "2026-04-12T13:56:00Z"^^xsd:dateTimeStamp .

ex:M_InYard_50  a mar:InYard ;
    dmfo:manifestationOf      ex:CONT_50 ;
    dmfo:stateWasGeneratedBy  ex:CraneTrf_50 ;
    dmfo:manifestationTimestamp "2026-04-12T14:00:00Z"^^xsd:dateTimeStamp .

ex:M_GateOut_50  a mar:GateOut ;
    dmfo:manifestationOf      ex:CONT_50 ;
    dmfo:stateWasGeneratedBy  ex:GateOut_50 ;
    dmfo:evidencedBy          ex:Obs_GateRead_50 ;
    dmfo:manifestationTimestamp "2026-04-12T17:50:00Z"^^xsd:dateTimeStamp .

# Custody + customs situations
ex:Sit_Custody_50  a mar:CustodyTransferSituation ;
    dul:includesObject ex:M_InYard_50 , ex:M_Discharged_50 ;
    dmfo:governedBy    ex:Regime_ISPS ;
    dmfo:inZone        ex:ISPSZone_CTA .

ex:Sit_Customs_50  a mar:CustomsControlSituation ;
    dul:includesObject ex:M_GateOut_50 ;
    dmfo:governedBy    ex:Regime_EU_UCC ;
    dmfo:inZone        ex:Gate_CTA_South .

# LCL deconsolidation chain (every 5th container)
ex:CargoLot_BL_50  a mar:CargoLot , dmfo:SplitSourceIdentity ;
    dmfo:hasIdentifier "BL-50" ;
    dmfo:identifierScheme "urn:un:cefact:bl"^^xsd:anyURI .

ex:Decon_τ_50  a mar:DeconsolidationActivity ;
    prov:wasInformedBy ex:GateOut_50 ;
    prov:wasAssociatedWith ex:Agent_CFSOperator ;
    prov:qualifiedUsage [
        a prov:Usage ;
        prov:entity  ex:M_GateOut_50 ;
        prov:hadRole ex:Role_GroupageInput
    ] .

ex:CargoSubLot_50_a  a mar:CargoLot ;
    dmfo:hasIdentifier "HBL-50-A" ;
    prov:wasDerivedFrom ex:CargoLot_BL_50 ;
    prov:wasGeneratedBy ex:Decon_τ_50 .
ex:CargoSubLot_50_b  a mar:CargoLot ;
    dmfo:hasIdentifier "HBL-50-B" ;
    prov:wasDerivedFrom ex:CargoLot_BL_50 ;
    prov:wasGeneratedBy ex:Decon_τ_50 .
ex:CargoSubLot_50_c  a mar:CargoLot ;
    dmfo:hasIdentifier "HBL-50-C" ;
    prov:wasDerivedFrom ex:CargoLot_BL_50 ;
    prov:wasGeneratedBy ex:Decon_τ_50 .

ex:M_Distributed_50_a  a mar:Distributed ;
    dmfo:manifestationOf ex:CargoSubLot_50_a ;
    dmfo:stateWasGeneratedBy ex:Decon_τ_50 ;
    dmfo:manifestationTimestamp "2026-04-12T21:50:00Z"^^xsd:dateTimeStamp .
ex:M_Distributed_50_b  a mar:Distributed ;
    dmfo:manifestationOf ex:CargoSubLot_50_b ;
    dmfo:stateWasGeneratedBy ex:Decon_τ_50 ;
    dmfo:manifestationTimestamp "2026-04-12T21:50:00Z"^^xsd:dateTimeStamp .
ex:M_Distributed_50_c  a mar:Distributed ;
    dmfo:manifestationOf ex:CargoSubLot_50_c ;
    dmfo:stateWasGeneratedBy ex:Decon_τ_50 ;
    dmfo:manifestationTimestamp "2026-04-12T21:50:00Z"^^xsd:dateTimeStamp .

# Class IV gaps (ABox-size-independent)
ex:CONT_GAP_evidence  a mar:Container ;
    mar:bicCode "GAPE0000001" ;
    dmfo:identifierScheme "urn:iso:std:iso:6346"^^xsd:anyURI .
ex:M_GAP_NoEvidence  a mar:InYard ;
    dmfo:manifestationOf ex:CONT_GAP_evidence ;
    dmfo:manifestationTimestamp "2026-04-12T10:00:00Z"^^xsd:dateTimeStamp .

ex:CONT_GAP_causal  a mar:Container ;
    mar:bicCode "GAPC0000002" ;
    dmfo:identifierScheme "urn:iso:std:iso:6346"^^xsd:anyURI .
ex:M_GAP_NoCausal  a mar:InYard ;
    dmfo:manifestationOf ex:CONT_GAP_causal ;
    dmfo:manifestationTimestamp "2026-04-12T11:00:00Z"^^xsd:dateTimeStamp .

ex:CONT_GAP_scheme  a mar:Container ;
    mar:bicCode "GAPS0000003" .

ex:Sit_GAP_governance  a dul:Situation ;
    dul:includesObject ex:M_GAP_NoEvidence ;
    dmfo:inZone ex:Yard_CTA .
