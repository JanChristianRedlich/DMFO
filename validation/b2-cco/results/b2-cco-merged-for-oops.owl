  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco/maritime#CustodyTransfer_Act">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000005"/>
    <rdfs:label xml:lang="en">Custody-transfer act (the situation reified)</rdfs:label>
    <rdfs:comment xml:lang="en">ADR-004: the contextual situation is reified as the act token; the Process Regulation prescribes this act class.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco/maritime#DischargedLocationQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
