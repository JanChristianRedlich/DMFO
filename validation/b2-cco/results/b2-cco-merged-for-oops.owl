  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco#DocumentedAbsence_GeoSPARQL">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">ADR-005: no GeoSPARQL spatial-relation algebra</rdfs:label>
    <rdfs:comment>Only bfo:located in / has spatial part are available; no sfWithin / sfTouches / sfIntersects.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco/maritime#GateRead_Measurement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001163"/>
    <rdfs:label xml:lang="en">Gate-read measurement</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionInfo>1.0.0</owl:versionInfo>
    <rdfs:label xml:lang="en">B2-CCO Baseline (DMFO evaluation)</rdfs:label>
    <rdfs:comment xml:lang="en">Alternative-architecture baseline for the DMFO ISWC paper.
Imports CCO 2.0 (and BFO 2020 transitively) and adds nothing that
re-introduces DMFO's typed bridges. Each modelling decision is
recorded in docs/adr/. The Faithful-Translation-Rule (F1-F5) is the
governing compliance criterion.</rdfs:comment>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-03</dcterms:created>
    <owl:imports rdf:resource="https://www.commoncoreontologies.org/CommonCoreOntologiesMerged/v2.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco/maritime#OnVesselLocationQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dmfo/baseline/cco/maritime#LocationQuality"/>
    <rdfs:label xml:lang="en">OnVessel location quality</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco/maritime#InYardLocationQuality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
