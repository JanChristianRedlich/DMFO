  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco/maritime#CraneTransfer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000005"/>
    <rdfs:label xml:lang="en">Crane transfer act</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco#DocumentedAbsence_StateAnchor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdfs:label xml:lang="en">ADR-001: no CCO equivalent of dmfo:Manifestation</rdfs:label>
    <rdfs:comment>State-of-an-entity-at-a-moment is modelled via bfo:Quality + bfo:inheres in + cco:Stasis of Quality.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco/maritime#Container">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000020"/>
    <rdfs:label xml:lang="en">ISO 6346 sea container</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dmfo/baseline/cco/maritime#ISPSZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
    <rdfs:label xml:lang="en">ISPS-restricted zone</rdfs:label>
